# Platform
NODE_ENV=development
LOG_LEVEL=info

# PostgreSQL
DATABASE_URL=postgres://rar:rar@localhost:5432/rar

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=recoverable-agent-runtime
TEMPORAL_TASK_QUEUE=rar-fulfillment

# API
API_HOST=0.0.0.0
API_PORT=8080
API_BEARER_TOKEN=dev-api-token-change-me

# Service identities (least privilege — rotate in real deploys)
WORKER_SERVICE_TOKEN=dev-worker-token-change-me
PROVIDERS_SERVICE_TOKEN=dev-providers-token-change-me
DASHBOARD_TOKEN=dev-dashboard-token-change-me

# Evidence
EVIDENCE_HMAC_SECRET=dev-evidence-hmac-secret-change-me-32b

# Failure injection (tests/demo only)
FAILURE_INJECTION_ENABLED=false

# Provider base URLs
INVENTORY_URL=http://localhost:8091
PAYMENT_URL=http://localhost:8092
EMAIL_URL=http://localhost:8093
CRM_URL=http://localhost:8094

# OTEL (optional collector)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=rar-api
